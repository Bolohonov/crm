<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V107-1" author="platform" labels="tenant,orders">
        <comment>Orders with denormalized total_amount</comment>

        <createTable tableName="orders">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_orders_customer"
                             references="customers(id)"/>
            </column>
            <column name="status_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_orders_status"
                             references="order_statuses(id)"/>
            </column>
            <column name="author_id" type="UUID" remarks="Кто создал (users.id)"/>
            <column name="total_amount" type="NUMERIC(14,2)" defaultValueNumeric="0"
                    remarks="Денормализованная сумма заказа = SUM(order_items.total_price)">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="TEXT"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="orders" indexName="idx_orders_customer_id">
            <column name="customer_id"/>
        </createIndex>
        <createIndex tableName="orders" indexName="idx_orders_status_id">
            <column name="status_id"/>
        </createIndex>
        <createIndex tableName="orders" indexName="idx_orders_created_at">
            <column name="created_at"/>
        </createIndex>

        <sql>
            CREATE TRIGGER trg_orders_updated_at
                BEFORE UPDATE ON orders
                FOR EACH ROW EXECUTE FUNCTION set_updated_at();
        </sql>

        <rollback>
            <dropTable tableName="orders"/>
        </rollback>
    </changeSet>

    <changeSet id="V107-2" author="platform" labels="tenant,orders">
        <comment>Order items (line items)</comment>

        <createTable tableName="order_items">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_order_items_order"
                             references="orders(id)"
                             deleteCascade="true"/>
            </column>
            <column name="product_id" type="UUID">
                <constraints foreignKeyName="fk_order_items_product"
                             references="products(id)"/>
            </column>
            <column name="product_name" type="VARCHAR(500)"
                    remarks="Денормализация — название товара на момент заказа">
                <constraints nullable="false"/>
            </column>
            <column name="product_sku" type="VARCHAR(100)"/>
            <column name="product_unit" type="VARCHAR(20)" defaultValue="шт"/>
            <column name="quantity" type="NUMERIC(10,3)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="NUMERIC(14,2)"
                    remarks="Цена на момент заказа — не меняется при изменении прайса">
                <constraints nullable="false"/>
            </column>
            <column name="total_price" type="NUMERIC(14,2)"
                    remarks="= quantity * price, вычисляется приложением">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="order_items" indexName="idx_order_items_order_id">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="order_items" indexName="idx_order_items_product_id">
            <column name="product_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="order_items"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
