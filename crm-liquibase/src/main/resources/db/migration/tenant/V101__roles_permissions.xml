<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V101-1" author="platform" labels="tenant,rbac">
        <comment>Create updated_at trigger function in tenant schema</comment>
        <sql splitStatements="false">
            CREATE OR REPLACE FUNCTION set_updated_at()
            RETURNS TRIGGER AS $BODY$
            BEGIN
                NEW.updated_at = NOW();
                RETURN NEW;
            END;
            $BODY$ LANGUAGE plpgsql;
        </sql>
        <rollback>
            DROP FUNCTION IF EXISTS set_updated_at();
        </rollback>
    </changeSet>

    <changeSet id="V101-2" author="platform" labels="tenant,rbac">
        <comment>Permissions — atomic capability codes</comment>

        <createTable tableName="permissions">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(100)" remarks="e.g. CUSTOMER_VIEW, ORDER_CREATE">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_permissions_code"/>
            </column>
            <column name="name" type="VARCHAR(255)" remarks="Человекочитаемое название">
                <constraints nullable="false"/>
            </column>
            <column name="group_name" type="VARCHAR(50)"
                    remarks="CUSTOMERS | TASKS | ORDERS | PRODUCTS | ADMIN | SYSTEM">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="permissions" indexName="idx_permissions_group">
            <column name="group_name"/>
        </createIndex>

        <rollback>
            <dropTable tableName="permissions"/>
        </rollback>
    </changeSet>

    <changeSet id="V101-3" author="platform" labels="tenant,rbac">
        <comment>Roles</comment>

        <createTable tableName="roles">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_roles_code"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="color" type="VARCHAR(20)" remarks="HEX color для UI: #3b82f6"/>
            <column name="is_system" type="BOOLEAN" defaultValueBoolean="false"
                    remarks="Системные роли нельзя удалить или переименовать">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            CREATE TRIGGER trg_roles_updated_at
                BEFORE UPDATE ON roles
                FOR EACH ROW EXECUTE FUNCTION set_updated_at();
        </sql>

        <rollback>
            <dropTable tableName="roles"/>
        </rollback>
    </changeSet>

    <changeSet id="V101-4" author="platform" labels="tenant,rbac">
        <comment>Role ↔ Permission many-to-many</comment>

        <createTable tableName="role_permissions">
            <column name="role_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_rp_role"
                             references="roles(id)"
                             deleteCascade="true"/>
            </column>
            <column name="permission_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_rp_permission"
                             references="permissions(id)"
                             deleteCascade="true"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="role_permissions"
                       columnNames="role_id, permission_id"
                       constraintName="pk_role_permissions"/>

        <createIndex tableName="role_permissions" indexName="idx_rp_permission_id">
            <column name="permission_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="role_permissions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
