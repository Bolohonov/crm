<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V103-1" author="platform" labels="tenant,statuses">
        <comment>Order statuses lookup — configurable per tenant</comment>

        <createTable tableName="order_statuses"
                     remarks="Справочник статусов заказов. Тенант может добавлять свои, системные нельзя удалить.">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)" remarks="NEW | IN_PROGRESS | DONE | CANCELLED | ...">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_order_statuses_code"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="color" type="VARCHAR(20)" remarks="HEX цвет для UI бейджа"/>
            <column name="sort_order" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_final" type="BOOLEAN" defaultValueBoolean="false"
                    remarks="Финальный статус — заказ закрыт (DONE, CANCELLED)">
                <constraints nullable="false"/>
            </column>
            <column name="is_system" type="BOOLEAN" defaultValueBoolean="false"
                    remarks="Системный — нельзя удалить">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="order_statuses" indexName="idx_order_statuses_sort">
            <column name="sort_order"/>
        </createIndex>

        <rollback>
            <dropTable tableName="order_statuses"/>
        </rollback>
    </changeSet>

    <changeSet id="V103-2" author="platform" labels="tenant,statuses">
        <comment>Task statuses lookup</comment>

        <createTable tableName="task_statuses">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_task_statuses_code"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="color" type="VARCHAR(20)"/>
            <column name="sort_order" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_final" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_system" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="task_statuses"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
