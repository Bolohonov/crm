<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V106-1" author="platform" labels="tenant,products">
        <comment>Products / services catalog</comment>

        <createTable tableName="products">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="sku" type="VARCHAR(100)" remarks="Артикул"/>
            <column name="price" type="NUMERIC(14,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="VARCHAR(20)" defaultValue="шт"
                    remarks="шт | кг | л | м | м² | час | день | усл."/>
            <column name="category_id" type="UUID" remarks="Категория (будущая таблица)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="products" columnNames="sku"
                             constraintName="uq_products_sku"/>

        <createIndex tableName="products" indexName="idx_products_is_active">
            <column name="is_active"/>
        </createIndex>

        <sql>
            CREATE INDEX idx_products_fts ON products
                USING gin(to_tsvector('russian_unaccent',
                    coalesce(name,'') || ' ' || coalesce(sku,'') || ' ' || coalesce(description,'')));

            CREATE TRIGGER trg_products_updated_at
                BEFORE UPDATE ON products
                FOR EACH ROW EXECUTE FUNCTION set_updated_at();
        </sql>

        <rollback>
            <dropTable tableName="products"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
