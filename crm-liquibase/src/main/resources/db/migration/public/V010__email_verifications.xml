<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V010-1" author="platform" labels="public,auth">
        <comment>Email verification tokens table</comment>

        <createTable tableName="email_verifications" schemaName="public">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(128)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="used" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="email_verifications" schemaName="public"
                     indexName="idx_email_verifications_token">
            <column name="token"/>
        </createIndex>

        <createIndex tableName="email_verifications" schemaName="public"
                     indexName="idx_email_verifications_user_id">
            <column name="user_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="email_verifications" schemaName="public"/>
        </rollback>
    </changeSet>

</databaseChangeLog>